<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Treinadores | Arena Admin</title>
  <link rel="stylesheet" href="/style.css">
  <style>
  /* Importando uma fonte moderna e esportiva do Google Fonts */
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap');

  :root {
    /* Tema Copa / Brasil Moderno */
    --brazil-blue: #002776;
    --brazil-green: #009c3b;
    --brazil-yellow: #fedf00;

    /* Painéis de Vidro com tom azulado escuro para dar contraste */
    --bg-glass: rgba(0, 39, 118, 0.6); 
    --blur: blur(15px);
    --border-glass: rgba(254, 223, 0, 0.4); /* Bordinha amarela moderna */
    
    /* Sombras modernas (suaves e amplas) */
    --shadow-md: 0 8px 15px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 15px 35px rgba(0, 156, 59, 0.3);
    
    /* Brilhos (Glows) vibrantes */
    --green-glow: rgba(0, 156, 59, 0.7);
    --yellow-glow: rgba(254, 223, 0, 0.6);
    
    /* Cores principais atualizadas */
    --green: #00e676; /* Um verde um pouco mais neon para botões ficarem clicáveis */
    --yellow: #fedf00;
    --red: #ff1744;
    --red-dim: rgba(255, 23, 68, 0.15);

    /* Textos */
    --text-primary: #ffffff;
    --text-secondary: #f0f0f0;
    --text-muted: rgba(255, 255, 255, 0.6);
    
    /* Substituindo a fonte pixelada por uma fonte moderna e limpa */
    --font-pixel: 'Poppins', sans-serif;
    --font-main: 'Poppins', sans-serif;

    /* Bordas mais arredondadas para um visual de App atual */
    --radius: 16px;
    --radius-sm: 8px;
  }
  
  body {
    /* Fundo com gradiente moderno: Azul escuro descendo para Verde bandeira */
    background: linear-gradient(135deg, #001233 0%, #002776 50%, #005024 100%);
    background-attachment: fixed;
    color: var(--text-primary);
    font-family: var(--font-main);
    min-height: 100vh;
    overflow-y: auto;
    margin: 0;
  }

  /* Deixando os títulos com a cara da Copa */
  h1, h2, h3 {
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--brazil-yellow);
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  /* Ajuste para garantir que qualquer tabela ou lista fique legível */
  .glass-panel {
    background: var(--bg-glass);
    backdrop-filter: var(--blur);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

    body {
      min-height: 100vh;
      overflow-y: auto;
    }

    .admin-shell {
      width: min(1200px, calc(100vw - 32px));
      margin: 0 auto;
      padding: 24px 0 36px;
      display: grid;
      gap: 16px;
    }

    .admin-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 68px;
      padding: 14px 20px;
      background: var(--bg-glass);
      backdrop-filter: var(--blur);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius);
      box-shadow: var(--shadow-md);
    }
    .admin-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }
    .admin-logo {
      width: 48px;
      height: 48px;
      object-fit: contain;
      image-rendering: pixelated;
      filter: drop-shadow(0 0 12px var(--green-glow));
    }
    .admin-brand h1 {
      margin: 0;
      color: var(--green);
      font-family: var(--font-pixel);
      font-size: clamp(22px, 3vw, 32px);
      line-height: 1;
      text-transform: uppercase;
    }
    .admin-brand span {
      display: block;
      margin-bottom: 3px;
      color: var(--text-muted);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .topbar-actions .habbo-btn {
      min-height: 40px;
      padding: 0 14px;
      font-size: 14px;
    }

    .operation-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      align-items: center;
      padding: 20px;
      background: var(--bg-glass);
      backdrop-filter: var(--blur);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius);
      box-shadow: var(--shadow-md);
    }
    .match-readout {
      display: grid;
      grid-template-columns: 160px minmax(180px, 1fr) 130px 100px;
      gap: 12px;
      align-items: stretch;
    }
    .readout {
      min-width: 0;
      padding: 12px 14px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius-sm);
    }
    .readout span {
      display: block;
      color: var(--text-muted);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .readout strong {
      display: block;
      margin-top: 4px;
      overflow: hidden;
      color: var(--text-primary);
      font-family: var(--font-pixel);
      font-size: 26px;
      line-height: 1.1;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .status-readout strong { color: var(--green); }
    .score-readout strong { font-size: 36px; text-align: center; }

    .primary-actions {
      display: grid;
      grid-template-columns: repeat(4, 124px);
      gap: 10px;
    }
    .primary-actions .habbo-btn {
      min-height: 52px;
      padding: 0 12px;
      font-size: 14px;
    }
    .btn-neutral {
      background: rgba(255, 255, 255, 0.1) !important;
      color: var(--text-primary) !important;
      border: 1px solid var(--border-glass) !important;
    }
    .btn-neutral:hover {
      background: rgba(255, 255, 255, 0.15) !important;
    }
    .btn-warning {
      background: var(--yellow-dim) !important;
      color: var(--yellow) !important;
      border: 1px solid rgba(255, 214, 0, 0.2) !important;
    }
    .btn-warning:hover {
      background: rgba(255, 214, 0, 0.2) !important;
      box-shadow: 0 4px 20px var(--yellow-glow) !important;
    }
    .btn-danger-admin {
      background: var(--red-dim) !important;
      color: var(--red) !important;
      border: 1px solid rgba(255, 23, 68, 0.2) !important;
    }
    .btn-danger-admin:hover {
      background: rgba(255, 23, 68, 0.2) !important;
      box-shadow: 0 4px 20px rgba(255, 23, 68, 0.3) !important;
    }

    .maintenance {
      background: var(--bg-glass);
      backdrop-filter: var(--blur);
      border: 1px solid var(--border-glass);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
    }
    .maintenance summary {
      cursor: pointer;
      padding: 14px 18px;
      color: var(--text-secondary);
      font-family: var(--font-main);
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .maintenance-panel {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      padding: 0 18px 18px;
    }
    .maintenance-panel .habbo-btn {
      min-height: 40px;
      padding: 0 14px;
      font-size: 13px;
    }

    .admin-board {
      display: grid;
      grid-template-columns: 1fr 1fr 1.25fr;
      gap: 16px;
      align-items: start;
    }
    .panel-scroll {
      max-height: 460px;
      overflow: auto;
    }
    .ranking-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-main);
      font-size: 14px;
    }
    .ranking-table th,
    .ranking-table td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border-glass);
      text-align: left;
      white-space: nowrap;
      color: var(--text-primary);
    }
    .ranking-table th {
      color: var(--text-muted);
      text-transform: uppercase;
      font-size: 11px;
      letter-spacing: 1px;
      background: rgba(0, 200, 83, 0.08);
      border-bottom: 1px solid var(--border-glass);
    }
    .ranking-table tr:nth-child(even) { background: rgba(255, 255, 255, 0.02); }
    .ranking-table tr:hover { background: rgba(255, 255, 255, 0.04); }
    .ranking-wrap { overflow-x: auto; }

    @media (max-width: 1060px) {
      .operation-card,
      .admin-board,
      .match-readout {
        grid-template-columns: 1fr;
      }
      .primary-actions {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 620px) {
      .admin-topbar {
        align-items: flex-start;
        flex-direction: column;
      }
      .topbar-actions,
      .primary-actions {
        width: 100%;
      }
      .topbar-actions .habbo-btn,
      .topbar-actions a,
      .primary-actions .habbo-btn {
        flex: 1;
        width: 100%;
      }
      .admin-shell {
        padding: 14px 0 24px;
        width: calc(100vw - 24px);
      }
    }
  </style>
</head>
<body>
  <main class="admin-shell">
    <header class="admin-topbar">
      <div class="admin-brand">
        <img src="/assets/Logo_Game.png" alt="Futzin" class="admin-logo">
        <div>
          <span>Painel dos treinadores</span>
          <h1>Futzin dos Treinadores</h1>
        </div>
      </div>
      <div class="topbar-actions">
        <a class="habbo-btn habbo-btn-green" href="/play?spectator=1" style="text-decoration: none; display: inline-flex; align-items: center;">Ver jogo</a>
        <form method="post" action="/admin/logout" style="margin: 0;">
          <button class="habbo-btn btn-neutral" type="submit">Sair</button>
        </form>
      </div>
    </header>

    <section class="operation-card" aria-label="Controle principal da partida">
      <div class="match-readout">
        <div class="readout status-readout"><span>Status</span><strong id="status">-</strong></div>
        <div class="readout score-readout"><span>Placar</span><strong id="score">0 x 0</strong></div>
        <div class="readout"><span>Tempo</span><strong id="time">3:00</strong></div>
        <div class="readout"><span>Fila</span><strong id="queue-count">0</strong></div>
      </div>
      <div class="primary-actions">
        <button class="habbo-btn habbo-btn-green" data-action="unlock">Liberar</button>
        <button class="habbo-btn habbo-btn-green" data-action="start">Iniciar</button>
        <button class="habbo-btn btn-neutral" data-action="pause">Pausar</button>
        <button class="habbo-btn btn-neutral" data-action="resume">Voltar</button>
      </div>
    </section>

    <details class="maintenance">
      <summary>Manutencao e acoes perigosas</summary>
      <div class="maintenance-panel">
        <button class="habbo-btn btn-neutral" data-action="lock">Bloquear arena</button>
        <button class="habbo-btn btn-danger-admin" data-action="end">Encerrar partida</button>
        <button class="habbo-btn btn-warning" data-action="reset-game">Reset jogo</button>
        <button class="habbo-btn btn-warning" data-action="clear-queue">Limpar fila</button>
        <button class="habbo-btn btn-warning" data-action="clear-chat">Limpar chat</button>
        <button class="habbo-btn btn-danger-admin" data-action="reset-ranking">Reset ranking</button>
      </div>
    </details>

    <section class="admin-board">
      <section class="habbo-box">
        <div class="habbo-box-header">
          <h2 class="habbo-box-title">Jogando agora</h2>
          <span id="active-count" class="queue-count-badge">0/10</span>
        </div>
        <div class="habbo-box-content no-padding panel-scroll">
          <div id="active-list" class="admin-list"></div>
        </div>
      </section>

      <section class="habbo-box">
        <div class="habbo-box-header">
          <h2 class="habbo-box-title">Fila</h2>
        </div>
        <div class="habbo-box-content no-padding panel-scroll">
          <div id="queue-list" class="admin-list"></div>
        </div>
      </section>

      <section class="habbo-box">
        <div class="habbo-box-header">
          <h2 class="habbo-box-title">Ranking</h2>
        </div>
        <div class="habbo-box-content no-padding ranking-wrap panel-scroll">
          <table class="ranking-table">
            <thead><tr><th>#</th><th>Jogador</th><th>Pontos</th><th>Gols</th><th>Vitorias</th></tr></thead>
            <tbody id="ranking"></tbody>
          </table>
        </div>
      </section>
    </section>
  </main>

  <svg style="display: none; position: absolute; width: 0; height: 0;">
    <filter id="crispify">
      <feComponentTransfer><feFuncA type="discrete" tableValues="0 1"/></feComponentTransfer>
    </filter>
  </svg>

  <script>
    const $ = (id) => document.getElementById(id);
    const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
    }[char]));
    const HABBO_MISSING_KEY = 'missingHabboHeads';
    const missingHabboHeads = new Set(loadMissingHabboHeads());
    function loadMissingHabboHeads() { try { return JSON.parse(localStorage.getItem(HABBO_MISSING_KEY) || '[]'); } catch (err) { return []; } }
    function saveMissingHabboHeads() { localStorage.setItem(HABBO_MISSING_KEY, JSON.stringify([...missingHabboHeads])); }
    function habboKey(name) { return String(name ?? '').trim().toLowerCase(); }
    const headUrl = (name) => `https://www.habbo.com.br/habbo-imaging/avatarimage?user=${encodeURIComponent(String(name ?? '').trim())}&headonly=1&direction=2&head_direction=2&gesture=sml&size=s`;
    function onHabboHeadError(img) {
      const key = habboKey(img?.dataset?.habboName);
      if (key) { missingHabboHeads.add(key); saveMissingHabboHeads(); }
      img?.remove();
    }
    window.onHabboHeadError = onHabboHeadError;
    const habboHead = (name) => {
      const key = habboKey(name);
      if (!key || missingHabboHeads.has(key)) return '';
      return `<img class="habbo-head useFilter" data-habbo-name="${esc(name)}" src="${headUrl(name)}" alt="${esc(name)}" loading="lazy" referrerpolicy="no-referrer" onerror="onHabboHeadError(this)">`;
    };
    const nameWithHead = (name) => `<span class="name-with-head">${habboHead(name)}<span>${esc(name)}</span></span>`;

    function fmt(sec) {
      sec = Math.max(0, Number(sec || 0));
      return `${Math.floor(sec / 60)}:${String(sec % 60).padStart(2, '0')}`;
    }

    function statusText(status) {
      const labels = {
        LOCKED: 'Bloqueado',
        WAITING: 'Aguardando',
        COUNTDOWN: 'Comecando',
        PLAYING: 'Em jogo',
        GOLDEN_GOAL: 'Gol de ouro',
        BETWEEN_MATCH: 'Intervalo',
        PAUSED: 'Pausado'
      };
      return labels[status] ?? status;
    }

    async function post(action, body = {}) {
      const destructive = {
        end: 'Encerrar a partida atual?',
        'reset-game': 'Resetar o jogo e recomecar a arena?',
        'clear-queue': 'Limpar toda a fila?',
        'reset-ranking': 'Resetar todo o ranking?'
      };
      if (destructive[action] && !confirm(destructive[action])) return;
      await fetch(`/admin/api/${action}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      await load();
    }

    function renderList(id, rows, active) {
      $(id).innerHTML = rows.map((row) => `
        <div class="admin-item">
          <div class="queue-name"><strong>${nameWithHead(row.name)}</strong><small>${active ? `Time ${esc(row.team)}` : `#${row.index}`}</small></div>
          <button class="habbo-btn" style="padding: 2px 12px; font-size: 12px; min-height: 32px;" data-remove="${esc(row.name)}">KIKAR</button>
        </div>
      `).join('') || '<div class="admin-item"><small>Vazio</small></div>';
    }

    async function load() {
      const res = await fetch('/admin/api/state');
      const state = await res.json();
      $('status').innerText = statusText(state.status);
      $('score').innerText = `${state.scoreA} x ${state.scoreB}`;
      $('time').innerText = state.status === 'GOLDEN_GOAL' ? 'golden' : fmt(state.timeLeft);
      $('queue-count').innerText = state.queue.length;
      $('active-count').innerText = `${state.active.length}/10`;
      renderList('active-list', state.active, true);
      renderList('queue-list', state.queue, false);
      $('ranking').innerHTML = state.ranking.map((row, index) => `
        <tr><td>${index + 1}</td><td>${nameWithHead(row.name)}</td><td><strong>${row.points}</strong></td><td>${row.goals}</td><td>${row.wins}</td></tr>
      `).join('');
      document.querySelectorAll('[data-remove]').forEach((btn) => {
        btn.onclick = () => {
          if (confirm(`Remover ${btn.dataset.remove} da arena?`)) post('remove-player', { name: btn.dataset.remove });
        };
      });
    }

    document.querySelectorAll('[data-action]').forEach((btn) => {
      btn.onclick = () => post(btn.dataset.action);
    });

    load();
    setInterval(load, 2000);
  </script>
</body>
</html>
