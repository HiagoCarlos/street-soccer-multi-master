<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Treinadores | Arena Admin</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    body {
      min-height: 100vh;
      overflow-y: auto;
      background: #181818 url("/assets/bg.png") no-repeat center center fixed;
      background-size: cover;
      color: #000;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      background: linear-gradient(180deg, rgba(0,0,0,.56), rgba(0,0,0,.26) 44%, rgba(0,0,0,.7));
    }

    .admin-shell {
      width: min(1160px, calc(100vw - 32px));
      margin: 0 auto;
      padding: 22px 0 34px;
      display: grid;
      gap: 14px;
    }

    .admin-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      min-height: 64px;
      padding: 10px 14px;
      background: rgba(228,226,223,.95);
      border: 2px solid #000;
      border-radius: 8px;
      box-shadow: 4px 4px 0 rgba(0,0,0,.35), inset 2px 2px 0 rgba(255,255,255,.55);
    }
    .admin-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }
    .admin-logo {
      width: 44px;
      height: 44px;
      object-fit: contain;
      image-rendering: pixelated;
      filter: drop-shadow(2px 2px 0 #000);
    }
    .admin-brand h1 {
      margin: 0;
      color: #cc1b1b;
      font-family: var(--font-pixel);
      font-size: clamp(22px, 3vw, 32px);
      line-height: 1;
      text-transform: uppercase;
    }
    .admin-brand span {
      display: block;
      margin-bottom: 3px;
      color: #555;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .topbar-actions .habbo-btn {
      min-height: 36px;
      padding: 0 12px;
      font-size: 15px;
    }

    .operation-card {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 16px;
      align-items: center;
      padding: 16px;
      background: var(--habbo-box-bg);
      border: 2px solid #000;
      border-radius: 8px;
      box-shadow: 4px 4px 0 rgba(0,0,0,.32), inset 2px 2px 0 rgba(255,255,255,.5);
    }
    .match-readout {
      display: grid;
      grid-template-columns: 150px minmax(180px, 1fr) 120px 90px;
      gap: 10px;
      align-items: stretch;
    }
    .readout {
      min-width: 0;
      padding: 10px 12px;
      background: #fff;
      border: 2px solid #000;
      border-radius: 4px;
      box-shadow: inset 2px 2px 4px rgba(0,0,0,.1);
    }
    .readout span {
      display: block;
      color: #666;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .readout strong {
      display: block;
      margin-top: 3px;
      overflow: hidden;
      color: #111;
      font-family: var(--font-pixel);
      font-size: 24px;
      line-height: 1.1;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .status-readout strong { color: #cc1b1b; }
    .score-readout strong { font-size: 34px; text-align: center; }

    .primary-actions {
      display: grid;
      grid-template-columns: repeat(4, 118px);
      gap: 8px;
    }
    .primary-actions .habbo-btn {
      min-height: 48px;
      padding: 0 10px;
      font-size: 16px;
    }
    .btn-neutral { background: #d8d8d8; color: #111; }
    .btn-warning { background: #f0ad4e; color: #111; }
    .btn-danger-admin { background: #d9534f; color: #fff; text-shadow: 1px 1px 0 #000; }

    .maintenance {
      background: rgba(228,226,223,.94);
      border: 2px solid #000;
      border-radius: 8px;
      box-shadow: 4px 4px 0 rgba(0,0,0,.28), inset 2px 2px 0 rgba(255,255,255,.45);
    }
    .maintenance summary {
      cursor: pointer;
      padding: 10px 14px;
      color: #333;
      font-family: var(--font-pixel);
      font-size: 18px;
      text-transform: uppercase;
    }
    .maintenance-panel {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      padding: 0 14px 14px;
    }
    .maintenance-panel .habbo-btn {
      min-height: 36px;
      padding: 0 12px;
      font-size: 14px;
    }

    .admin-board {
      display: grid;
      grid-template-columns: 1fr 1fr 1.25fr;
      gap: 14px;
      align-items: start;
    }
    .panel-scroll {
      max-height: 430px;
      overflow: auto;
    }
    .ranking-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-standard);
      font-size: 13px;
    }
    .ranking-table th,
    .ranking-table td {
      padding: 9px;
      border-bottom: 1px solid #ccc;
      text-align: left;
      white-space: nowrap;
    }
    .ranking-table th {
      color: #555;
      text-transform: uppercase;
      background: #e4e2df;
      border-bottom: 2px solid #000;
    }
    .ranking-table tr:nth-child(even) { background: var(--habbo-grey-light); }
    .ranking-wrap { overflow-x: auto; }

    @media (max-width: 1060px) {
      .operation-card,
      .admin-board,
      .match-readout {
        grid-template-columns: 1fr;
      }
      .primary-actions {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 620px) {
      .admin-topbar {
        align-items: flex-start;
        flex-direction: column;
      }
      .topbar-actions,
      .primary-actions {
        width: 100%;
      }
      .topbar-actions .habbo-btn,
      .topbar-actions a,
      .primary-actions .habbo-btn {
        flex: 1;
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <main class="admin-shell">
    <header class="admin-topbar">
      <div class="admin-brand">
        <img src="/assets/Logo_Game.png" alt="Futzin" class="admin-logo">
        <div>
          <span>Painel dos treinadores</span>
          <h1>Futzin dos Treinadores</h1>
        </div>
      </div>
      <div class="topbar-actions">
        <a class="habbo-btn habbo-btn-green" href="/play?spectator=1" style="text-decoration: none; display: inline-flex; align-items: center;">Ver jogo</a>
        <form method="post" action="/admin/logout" style="margin: 0;">
          <button class="habbo-btn btn-neutral" type="submit">Sair</button>
        </form>
      </div>
    </header>

    <section class="operation-card" aria-label="Controle principal da partida">
      <div class="match-readout">
        <div class="readout status-readout"><span>Status</span><strong id="status">-</strong></div>
        <div class="readout score-readout"><span>Placar</span><strong id="score">0 x 0</strong></div>
        <div class="readout"><span>Tempo</span><strong id="time">3:00</strong></div>
        <div class="readout"><span>Fila</span><strong id="queue-count">0</strong></div>
      </div>
      <div class="primary-actions">
        <button class="habbo-btn habbo-btn-green" data-action="unlock">Liberar</button>
        <button class="habbo-btn habbo-btn-green" data-action="start">Iniciar</button>
        <button class="habbo-btn btn-neutral" data-action="pause">Pausar</button>
        <button class="habbo-btn btn-neutral" data-action="resume">Voltar</button>
      </div>
    </section>

    <details class="maintenance">
      <summary>Manutenção e ações perigosas</summary>
      <div class="maintenance-panel">
        <button class="habbo-btn btn-neutral" data-action="lock">Bloquear arena</button>
        <button class="habbo-btn btn-danger-admin" data-action="end">Encerrar partida</button>
        <button class="habbo-btn btn-warning" data-action="reset-game">Reset jogo</button>
        <button class="habbo-btn btn-warning" data-action="clear-queue">Limpar fila</button>
        <button class="habbo-btn btn-warning" data-action="clear-chat">Limpar chat</button>
        <button class="habbo-btn btn-danger-admin" data-action="reset-ranking">Reset ranking</button>
      </div>
    </details>

    <section class="admin-board">
      <section class="habbo-box">
        <div class="habbo-box-header">
          <h2 class="habbo-box-title">Jogando agora</h2>
          <span id="active-count" class="queue-count-badge">0/10</span>
        </div>
        <div class="habbo-box-content no-padding panel-scroll">
          <div id="active-list" class="admin-list"></div>
        </div>
      </section>

      <section class="habbo-box">
        <div class="habbo-box-header">
          <h2 class="habbo-box-title">Fila</h2>
        </div>
        <div class="habbo-box-content no-padding panel-scroll">
          <div id="queue-list" class="admin-list"></div>
        </div>
      </section>

      <section class="habbo-box">
        <div class="habbo-box-header">
          <h2 class="habbo-box-title">Ranking</h2>
        </div>
        <div class="habbo-box-content no-padding ranking-wrap panel-scroll">
          <table class="ranking-table">
            <thead><tr><th>#</th><th>Jogador</th><th>Pontos</th><th>Gols</th><th>Vitórias</th></tr></thead>
            <tbody id="ranking"></tbody>
          </table>
        </div>
      </section>
    </section>
  </main>

  <svg style="display: none; position: absolute; width: 0; height: 0;">
    <filter id="crispify">
      <feComponentTransfer><feFuncA type="discrete" tableValues="0 1"/></feComponentTransfer>
    </filter>
  </svg>

  <script>
    const $ = (id) => document.getElementById(id);
    const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
    }[char]));
    const HABBO_MISSING_KEY = 'missingHabboHeads';
    const missingHabboHeads = new Set(loadMissingHabboHeads());
    function loadMissingHabboHeads() { try { return JSON.parse(localStorage.getItem(HABBO_MISSING_KEY) || '[]'); } catch (err) { return []; } }
    function saveMissingHabboHeads() { localStorage.setItem(HABBO_MISSING_KEY, JSON.stringify([...missingHabboHeads])); }
    function habboKey(name) { return String(name ?? '').trim().toLowerCase(); }
    const headUrl = (name) => `https://www.habbo.com.br/habbo-imaging/avatarimage?user=${encodeURIComponent(String(name ?? '').trim())}&headonly=1&direction=2&head_direction=2&gesture=sml&size=s`;
    function onHabboHeadError(img) {
      const key = habboKey(img?.dataset?.habboName);
      if (key) { missingHabboHeads.add(key); saveMissingHabboHeads(); }
      img?.remove();
    }
    window.onHabboHeadError = onHabboHeadError;
    const habboHead = (name) => {
      const key = habboKey(name);
      if (!key || missingHabboHeads.has(key)) return '';
      return `<img class="habbo-head useFilter" data-habbo-name="${esc(name)}" src="${headUrl(name)}" alt="${esc(name)}" loading="lazy" referrerpolicy="no-referrer" onerror="onHabboHeadError(this)">`;
    };
    const nameWithHead = (name) => `<span class="name-with-head">${habboHead(name)}<span>${esc(name)}</span></span>`;

    function fmt(sec) {
      sec = Math.max(0, Number(sec || 0));
      return `${Math.floor(sec / 60)}:${String(sec % 60).padStart(2, '0')}`;
    }

    function statusText(status) {
      const labels = {
        LOCKED: 'Bloqueado',
        WAITING: 'Aguardando',
        COUNTDOWN: 'Começando',
        PLAYING: 'Em jogo',
        GOLDEN_GOAL: 'Gol de ouro',
        BETWEEN_MATCH: 'Intervalo',
        PAUSED: 'Pausado'
      };
      return labels[status] ?? status;
    }

    async function post(action, body = {}) {
      const destructive = {
        end: 'Encerrar a partida atual?',
        'reset-game': 'Resetar o jogo e recomeçar a arena?',
        'clear-queue': 'Limpar toda a fila?',
        'reset-ranking': 'Resetar todo o ranking?'
      };
      if (destructive[action] && !confirm(destructive[action])) return;
      await fetch(`/admin/api/${action}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      await load();
    }

    function renderList(id, rows, active) {
      $(id).innerHTML = rows.map((row) => `
        <div class="admin-item">
          <div class="queue-name"><strong>${nameWithHead(row.name)}</strong><small>${active ? `Time ${esc(row.team)}` : `#${row.index}`}</small></div>
          <button class="habbo-btn" style="padding: 2px 10px; font-size: 12px;" data-remove="${esc(row.name)}">KIKAR</button>
        </div>
      `).join('') || '<div class="admin-item"><small>Vazio</small></div>';
    }

    async function load() {
      const res = await fetch('/admin/api/state');
      const state = await res.json();
      $('status').innerText = statusText(state.status);
      $('score').innerText = `${state.scoreA} x ${state.scoreB}`;
      $('time').innerText = state.status === 'GOLDEN_GOAL' ? 'golden' : fmt(state.timeLeft);
      $('queue-count').innerText = state.queue.length;
      $('active-count').innerText = `${state.active.length}/10`;
      renderList('active-list', state.active, true);
      renderList('queue-list', state.queue, false);
      $('ranking').innerHTML = state.ranking.map((row, index) => `
        <tr><td>${index + 1}</td><td>${nameWithHead(row.name)}</td><td><strong>${row.points}</strong></td><td>${row.goals}</td><td>${row.wins}</td></tr>
      `).join('');
      document.querySelectorAll('[data-remove]').forEach((btn) => {
        btn.onclick = () => {
          if (confirm(`Remover ${btn.dataset.remove} da arena?`)) post('remove-player', { name: btn.dataset.remove });
        };
      });
    }

    document.querySelectorAll('[data-action]').forEach((btn) => {
      btn.onclick = () => post(btn.dataset.action);
    });

    load();
    setInterval(load, 2000);
  </script>
</body>
</html>
